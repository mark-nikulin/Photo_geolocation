# Photo Geolocation Service — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================================
# DATABASE
# ============================================================
# For local development (SQLite, no setup required):
DATABASE_URL=sqlite+aiosqlite:///./geolocation.db

# For production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/geolocation

# ============================================================
# REDIS (optional — in-memory cache is used as fallback)
# ============================================================
# REDIS_URL=redis://localhost:6379

# ============================================================
# SECURITY
# ============================================================
# IMPORTANT: Change this in production! Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production-32chars!

# ============================================================
# GOOGLE CLOUD VISION API (required for landmark detection)
# ============================================================
# Path to your Google Cloud service account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ============================================================
# GOOGLE MAPS API (recommended for geocoding)
# ============================================================
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================================
# ALTERNATIVE GEOCODING PROVIDERS (optional)
# ============================================================
# LocationIQ: https://locationiq.com/ (5,000 req/day free)
# LOCATIONIQ_API_KEY=your-locationiq-api-key

# OpenCage: https://opencagedata.com/ (2,500 req/day free)
# OPENCAGE_API_KEY=your-opencage-api-key

# ============================================================
# APP SETTINGS (optional, defaults shown)
# ============================================================
# DEBUG=false
# HOST=0.0.0.0
# PORT=8000
